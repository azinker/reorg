# ─── Environment ──────────────────────────────────────────────────────────────
# local | staging | production
NEXT_PUBLIC_APP_ENV=local

# ─── Database (Neon recommended) ──────────────────────────────────────────────
# Pooled connection for runtime queries.
# Append ?connection_limit=10&pool_timeout=20 to increase Prisma's pool capacity
# beyond the default 5 connections / 10s timeout. Recommended for production.
DATABASE_URL="postgresql://user:password@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require&connection_limit=10&pool_timeout=20"
# Direct connection for Prisma migrations
DIRECT_URL="postgresql://user:password@ep-xxx.region.aws.neon.tech/neondb?sslmode=require"

# ─── Auth.js / NextAuth ──────────────────────────────────────────────────────
# Generate with: npx auth secret
AUTH_SECRET="generate-a-secret-here"
AUTH_URL="http://localhost:3000"

# ─── Resend (Email) ──────────────────────────────────────────────────────────
RESEND_API_KEY="re_xxxxxxxxxxxxx"
EMAIL_FROM="reorG <noreply@theperfectpart.net>"

# ─── eBay - TPP (The Perfect Part) ───────────────────────────────────────────
EBAY_TPP_APP_ID=""
EBAY_TPP_CERT_ID=""
EBAY_TPP_DEV_ID=""
EBAY_TPP_REFRESH_TOKEN=""
EBAY_TPP_ENVIRONMENT="PRODUCTION"

# ─── eBay - TT (Telitetech) ──────────────────────────────────────────────────
EBAY_TT_APP_ID=""
EBAY_TT_CERT_ID=""
EBAY_TT_DEV_ID=""
EBAY_TT_REFRESH_TOKEN=""
EBAY_TT_ENVIRONMENT="PRODUCTION"
EBAY_MARKETPLACE_ACCOUNT_DELETION_ENDPOINT=""
EBAY_MARKETPLACE_ACCOUNT_DELETION_VERIFICATION_TOKEN=""

# ─── BigCommerce ──────────────────────────────────────────────────────────────
BIGCOMMERCE_STORE_HASH=""
BIGCOMMERCE_ACCESS_TOKEN=""
NEXT_PUBLIC_BIGCOMMERCE_STORE_HASH=""

# ─── Stripe (BigCommerce payouts – Payouts page) ──────────────────────────────
# Stripe secret key — used server-side only to fetch payout history for BC store.
# Get it from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=""

# ─── Shopify (Dev Dashboard app – OAuth) ────────────────────────────────────
# From Partners: reorG app → API credentials
SHOPIFY_CLIENT_ID=""
SHOPIFY_CLIENT_SECRET=""
# Store handle or full domain, e.g. fd7279 or fd7279.myshopify.com
SHOPIFY_STORE_DOMAIN=""
# Optional: only needed if using legacy custom app token
SHOPIFY_ACCESS_TOKEN=""
SHOPIFY_API_VERSION="2026-01"
# Optional explicit Shopify webhook secret. Falls back to SHOPIFY_CLIENT_SECRET if blank.
SHOPIFY_WEBHOOK_SECRET=""

# ─── Amazon SP-API ───────────────────────────────────────────────────────────
# LWA (Login With Amazon) credentials — from Amazon Developer Central → app → LWA credentials
AMAZON_LWA_CLIENT_ID=""
AMAZON_LWA_CLIENT_SECRET=""
# AWS IAM user credentials (reorg-sp-api user) — for Signature V4 signing
AMAZON_AWS_ACCESS_KEY_ID=""
AMAZON_AWS_SECRET_ACCESS_KEY=""

# ─── Cloudflare R2 (Backups) ─────────────────────────────────────────────────
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET_NAME="reorg-backups"
R2_ENDPOINT="https://<ACCOUNT_ID>.r2.cloudflarestorage.com"

# ─── Scheduler / Webhooks ─────────────────────────────────────────────────────
CRON_SECRET=""
# Use this as a shared secret header when registering BigCommerce webhooks.
BIGCOMMERCE_WEBHOOK_SECRET=""

# ─── Write Safety ────────────────────────────────────────────────────────────
# Global write lock: true = all writes blocked
GLOBAL_WRITE_LOCK=true

# ─── Help Desk ───────────────────────────────────────────────────────────────
# Master kill-switch for outbound (eBay messages + Resend emails). When true,
# nothing is sent — sync, notes, drafts, and reads keep working.
# Default safe value: true. Set to false to enable real outbound sends.
HELPDESK_SAFE_MODE=true
# Allow eBay outbound (AddMemberMessageAAQToPartner / AddMemberMessageRTQ).
HELPDESK_ENABLE_EBAY_SEND=false
# Allow External composer mode (sends an email via Resend to the buyer).
HELPDESK_ENABLE_RESEND_EXTERNAL=false
# Allow outbound attachments. Inbound media is always shown regardless.
HELPDESK_ENABLE_ATTACHMENTS=false
# Optional dedicated Resend API key for Help Desk External composer. Falls back
# to RESEND_API_KEY if not set.
HELPDESK_RESEND_API_KEY="re_xxxxxxxxxxxxx"
# From-address for Help Desk External composer (Resend). Falls back to RESEND_FROM
# if not set. Must be on a verified Resend domain.
HELPDESK_RESEND_FROM="Sales@theperfectpart.net"
# Optional fallback used by other Resend calls in the app.
RESEND_FROM="noreply@theperfectpart.net"
