// ─── Help Desk eBay action mirrors ───────────────────────────────────────────
//
// These three tables mirror buyer-initiated actions on eBay (return cases,
// cancellation requests, feedback) so we can fold them into the ticket
// timeline without re-querying eBay every time a thread is opened. Each row
// is keyed by `externalId` from the eBay REST API and is upserted by a
// dedicated sync worker that runs alongside the message sync.
//
// READ-ONLY in v1: we never push to eBay from these tables. The user-facing
// surface is the timeline pill in ThreadView and the type-classification
// nudge on HelpdeskTicket.type.

enum HelpdeskCaseStatus {
  OPEN
  CLOSED
  AWAITING_SELLER
  AWAITING_BUYER
  ESCALATED
  CANCELLED
  REFUNDED
  UNKNOWN
}

enum HelpdeskCaseKind {
  RETURN
  ITEM_NOT_RECEIVED
  NOT_AS_DESCRIBED
  CHARGEBACK
  OTHER
}

/// eBay return / dispute case opened by the buyer. Sourced from eBay's REST
/// post-order Returns API. One row per eBay case; the `externalId` is the
/// eBay-issued case identifier (e.g. "5234567" for returns) which we expose
/// in the timeline pill so the agent can click through to manage the case
/// directly on eBay.
model HelpdeskCase {
  id              String             @id @default(cuid())
  integrationId   String
  /// Foreign-key to the matching HelpdeskTicket when we can resolve one by
  /// order number + buyer. Nullable so cases without a known ticket still
  /// get tracked (we'll attach later if a ticket appears).
  ticketId        String?
  /// eBay's case identifier — guaranteed unique within the integration.
  externalId      String
  kind            HelpdeskCaseKind
  status          HelpdeskCaseStatus @default(OPEN)
  ebayOrderNumber String?
  buyerUserId     String?
  /// Buyer-facing reason text shown on eBay (e.g. "Item not as described").
  reason          String?            @db.Text
  /// URL the agent can click to open the case directly on eBay.
  manageUrl       String?
  openedAt        DateTime
  closedAt        DateTime?
  rawData         Json               @default("{}")
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  @@unique([integrationId, externalId])
  @@index([ticketId, openedAt])
  @@index([ebayOrderNumber])
  @@index([buyerUserId])
  @@index([status, openedAt])
  @@map("helpdesk_cases")
}

enum HelpdeskFeedbackKind {
  POSITIVE
  NEUTRAL
  NEGATIVE
}

/// Buyer feedback on an order. Sourced from eBay Trading API GetFeedback.
/// Negative feedback drives a centered, red-tinted timeline pill and (when
/// the ticket type is still QUERY) flips ticket type to NEGATIVE_FEEDBACK so
/// the inbox column makes the situation obvious.
model HelpdeskFeedback {
  id              String               @id @default(cuid())
  integrationId   String
  ticketId        String?
  /// eBay's FeedbackID — unique within the integration. We dedupe on this.
  externalId      String
  kind            HelpdeskFeedbackKind
  /// 1..5 star rating when eBay supplies one; null otherwise.
  starRating      Int?
  /// Public comment the buyer left.
  comment         String?              @db.Text
  /// When provided, the agent's public reply to the feedback.
  sellerResponse  String?              @db.Text
  ebayOrderNumber String?
  ebayItemId      String?
  buyerUserId     String?
  /// URL of the feedback page on eBay (deep-link).
  manageUrl       String?
  leftAt          DateTime
  rawData         Json                 @default("{}")
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt

  @@unique([integrationId, externalId])
  @@index([ticketId, leftAt])
  @@index([ebayOrderNumber])
  @@index([buyerUserId])
  @@index([kind, leftAt])
  @@map("helpdesk_feedback")
}

enum HelpdeskCancellationStatus {
  REQUESTED
  APPROVED
  REJECTED
  COMPLETED
  CANCELLED_BY_BUYER
  UNKNOWN
}

/// Buyer-initiated cancellation request. Sourced from eBay's REST post-order
/// Cancellation API. Drives the "Buyer requested cancellation" timeline pill
/// and the auto-applied "Buyer Request Cancellation" tag (handled by
/// existing filter machinery against the resulting ticket).
model HelpdeskCancellation {
  id              String                     @id @default(cuid())
  integrationId   String
  ticketId        String?
  /// eBay cancellation request identifier — unique within the integration.
  externalId      String
  status          HelpdeskCancellationStatus @default(REQUESTED)
  /// Buyer-supplied reason (e.g. "buyerChangedMind", "orderMistake").
  reason          String?
  /// Refund amount when cancellation completed with a refund attached.
  refundAmount    Float?
  refundCurrency  String?                    @db.VarChar(8)
  ebayOrderNumber String?
  buyerUserId     String?
  /// URL the agent can click to open the cancellation on eBay.
  manageUrl       String?
  requestedAt     DateTime
  resolvedAt      DateTime?
  rawData         Json                       @default("{}")
  createdAt       DateTime                   @default(now())
  updatedAt       DateTime                   @updatedAt

  @@unique([integrationId, externalId])
  @@index([ticketId, requestedAt])
  @@index([ebayOrderNumber])
  @@index([buyerUserId])
  @@index([status, requestedAt])
  @@map("helpdesk_cancellations")
}

/// User-defined inbox rules (e.g. "Subject contains 'Shipped' → Archive").
/// Rules are evaluated against incoming messages on every sync tick AND can be
/// run on-demand against the existing inbox via `Run filter`.
///
/// `conditions` shape (JSON):
///   {
///     "match": "ALL" | "ANY",            // boolean combinator
///     "rules": [
///       { "field": "subject" | "body" | "buyer_username" | "from_name",
///         "op":    "contains" | "equals" | "starts_with" | "ends_with" | "regex",
///         "value": "...",
///         "caseSensitive": false }
///     ]
///   }
///
/// `action` shape (JSON):
///   {
///     "type": "MOVE_TO_FOLDER",
///     "folder": "archived" | "spam" | "resolved",
///     "addTagIds": ["..."],              // optional
///     "removeTagIds": ["..."],           // optional
///     "assignToUserId": "..."            // optional
///   }
model HelpdeskFilter {
  id          String    @id @default(cuid())
  name        String
  description String?
  enabled     Boolean   @default(true)
  isSystem    Boolean   @default(false)
  sortOrder   Int       @default(0)
  conditions  Json
  action      Json
  lastRunAt   DateTime?
  lastRunHits Int       @default(0)
  totalHits   Int       @default(0)
  createdById String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  createdBy User? @relation("HelpdeskFilterCreator", fields: [createdById], references: [id], onDelete: SetNull)

  @@index([enabled, sortOrder])
  @@map("helpdesk_filters")
}

// ─── Help Desk eBay Return Cases ─────────────────────────────────────────────
//
// Dedicated models for the eBay Return Cases feature (/help-desk/returns).
// These are intentionally SEPARATE from HelpdeskCase (the lightweight timeline
// mirror) and from message tickets — a return is a first-class operational
// object with its own lifecycle, files, tracking, and gated live actions.
//
// Source: eBay Post-Order Return API v2 (Search Returns / Get Return /
// Get Tracking / Get Files). Sync is PULL-ONLY — nothing in these tables ever
// triggers a write to eBay. Live seller actions are recorded as
// HelpdeskReturnActionAttempt rows and always pass the returns safety gate
// (admin + global lock + integration lock + returns live-write toggle + env +
// re-fetch + availability + preview + confirmation + audit). No delete paths.

enum HelpdeskReturnActionStatus {
  PREVIEWED
  COMMITTED
  FAILED
  BLOCKED
}

/// One eBay return request. Keyed by (integrationId, returnId). Stores both the
/// normalized list fields (for fast list/badge queries without parsing JSON)
/// and the full raw eBay payloads (summary from search, detail from get) for
/// traceability and the Admin debug panel.
model HelpdeskReturnCase {
  id              String   @id @default(cuid())
  integrationId   String
  /// Denormalized store platform (TPP_EBAY / TT_EBAY) so list filtering and
  /// store badges never need an Integration join.
  platform        Platform
  /// eBay return identifier (e.g. "5...."). Unique within the integration.
  returnId        String
  /// eBay order id this return is attached to (legacy "26-xxxxx-xxxxx" style).
  ebayOrderNumber String?
  /// Line-item identifiers from creationInfo.item.
  ebayItemId      String?
  transactionId   String?
  returnQuantity  Int?
  /// Item presentation (hydrated from order context / detail when available).
  itemTitle       String?  @db.Text
  imageUrl        String?
  sku             String?

  buyerUserId  String?
  sellerUserId String?

  /// Raw eBay ReturnStateEnum (e.g. RETURN_REQUESTED, ITEM_SHIPPED,
  /// ITEM_DELIVERED, CLOSED) and the human-ish status string. We keep them raw
  /// and compute the UI bucket in a pure helper so mapping changes don't need a
  /// migration.
  returnState     String?
  returnStatus    String?
  currentType     String?
  /// Set of eBay ReturnCountFilterEnum buckets this return appeared in on the
  /// most recent sync (e.g. ["ALL_OPEN","RETURN_STARTED","SELLER_ACTION_DUE"]
  /// or ["CLOSED"]). eBay's own "Manage returns" status dropdown is driven by
  /// these buckets, not by the raw state, so we mirror them here to make the
  /// list filters (in progress / shipped / delivered / closed) match Seller Hub
  /// exactly. Recomputed every sync.
  ebayBuckets     Json    @default("[]")
  /// True when eBay currently has an action due from the seller — drives the
  /// "needs attention" badge count. Recomputed on every sync.
  sellerActionDue Boolean @default(false)
  escalated       Boolean @default(false)
  caseId          String?

  reason        String? @db.Text
  reasonType    String?
  /// Buyer's free-text comment at return creation, when present.
  buyerComments String? @db.Text

  /// Refund amounts. "estimated" until eBay issues the refund, then "actual".
  sellerRefundValue    Float?
  sellerRefundCurrency String? @db.VarChar(8)
  buyerRefundValue     Float?
  buyerRefundCurrency  String? @db.VarChar(8)
  refundIsActual       Boolean @default(false)

  /// Deadlines from eBay.
  sellerResponseDueAt DateTime?
  buyerResponseDueAt  DateTime?
  timeoutDate         DateTime?

  /// Buyer's return-shipment tracking (from Get Return detail's
  /// returnShipmentInfo.shipmentTracking). Powers the "Return tracking" box +
  /// the Track Package modal and the feed into the GET /return/{id}/tracking
  /// scan-history call (carrierUsed + trackingNumber are required there).
  returnTrackingNumber String?
  returnCarrier        String?
  returnCarrierUsed    String?
  returnDeliveryStatus String?

  openedAt DateTime
  closedAt DateTime?

  /// Best-effort link to the matching conversation ticket (by order number +
  /// buyer). Nullable; never auto-creates a ticket.
  ticketId String?

  /// Snapshotted available options (AvailableOptionType[].actionType). These
  /// are advisory only — the safety gate ALWAYS re-validates against a fresh
  /// Get Return before any live write.
  sellerAvailableOptions Json @default("[]")
  buyerAvailableOptions  Json @default("[]")

  /// Full raw eBay payloads. rawSummary from search; rawDetail from get (null
  /// until a detail fetch happens). Exposed only in the Admin debug panel.
  rawSummary      Json      @default("{}")
  rawDetail       Json?
  detailFetchedAt DateTime?
  lastSyncedAt    DateTime  @default(now())

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  files          HelpdeskReturnFile[]
  trackingEvents HelpdeskReturnTrackingEvent[]
  actionAttempts HelpdeskReturnActionAttempt[]

  @@unique([integrationId, returnId])
  @@index([platform, openedAt])
  @@index([returnState])
  @@index([sellerActionDue])
  @@index([ebayOrderNumber])
  @@index([buyerUserId])
  @@index([ticketId])
  @@index([openedAt])
  @@map("helpdesk_return_cases")
}

/// A file attached to a return (buyer photo, uploaded return label, etc.).
/// Either mirrored from eBay (Get Files) or created by an agent upload that we
/// then pushed to eBay via file/upload. Append-only.
model HelpdeskReturnFile {
  id               String   @id @default(cuid())
  returnCaseId     String
  /// eBay fileId once known (from file/upload response or Get Files).
  ebayFileId       String?
  fileName         String?
  /// FilePurposeEnum: ITEM_RELATED | LABEL_RELATED | REFUND_RELATED | UNKNOWN.
  filePurpose      String?
  contentType      String?
  sizeBytes        Int?
  /// Where the file is viewable, when eBay returns a URL (secureUrl).
  /// For buyer photos this holds the small resized thumbnail (grid preview).
  url              String?  @db.Text
  /// Full-resolution inline data URL for buyer photos (lightbox/expand view).
  fullUrl          String?  @db.Text
  /// ReturnUserRoleEnum of who attached the file: BUYER | SELLER | EBAY |
  /// SYSTEM | OTHER. Used to surface buyer-uploaded photos in the comments UI.
  submitter        String?
  /// "EBAY" (synced) or "UPLOAD" (agent-provided then pushed).
  source           String   @default("EBAY")
  uploadedByUserId String?
  rawData          Json     @default("{}")
  createdAt        DateTime @default(now())

  returnCase HelpdeskReturnCase @relation(fields: [returnCaseId], references: [id], onDelete: Cascade)

  @@index([returnCaseId, createdAt])
  @@index([ebayFileId])
  @@map("helpdesk_return_files")
}

/// A single return-shipment tracking scan event (from Get Tracking). Deduped
/// on a stable fingerprint so repeated syncs don't duplicate scans.
model HelpdeskReturnTrackingEvent {
  id             String    @id @default(cuid())
  returnCaseId   String
  carrier        String?
  trackingNumber String?
  eventDate      DateTime?
  status         String?
  location       String?
  description    String?   @db.Text
  /// Stable hash of (eventDate|status|location|description) to dedupe scans.
  fingerprint    String
  rawData        Json      @default("{}")
  createdAt      DateTime  @default(now())

  returnCase HelpdeskReturnCase @relation(fields: [returnCaseId], references: [id], onDelete: Cascade)

  @@unique([returnCaseId, fingerprint])
  @@index([returnCaseId, eventDate])
  @@map("helpdesk_return_tracking_events")
}

/// Records every live-write attempt against a return — previewed, committed,
/// failed, or blocked. The idempotencyKey ties a preview to its single commit
/// so a double-click/retry can't fire two live eBay writes. Append-only; this
/// is the audit spine for return actions (in addition to AuditLog rows).
model HelpdeskReturnActionAttempt {
  id              String                     @id @default(cuid())
  returnCaseId    String
  integrationId   String
  userId          String?
  /// Our internal action key: APPROVE_RETURN, OFFER_PARTIAL_REFUND,
  /// UPLOAD_LABEL, CONFIRM_LABEL_SENT, MARK_AS_RECEIVED, ISSUE_REFUND.
  actionType      String
  status          HelpdeskReturnActionStatus @default(PREVIEWED)
  /// Server-generated token returned by preview; commit must echo it back so
  /// the committed payload matches exactly what was previewed.
  idempotencyKey  String
  /// Normalized human summary shown on the preview/confirmation screen.
  previewSummary  Json                       @default("{}")
  /// Exact eBay request body that will be / was sent (secrets never included).
  requestPayload  Json                       @default("{}")
  /// eBay response body (normalized) for committed/failed attempts.
  responsePayload Json?
  /// eBay request id (X-EBAY-C-REQUEST-ID style) when returned.
  ebayRequestId   String?
  /// When BLOCKED, the safety reason. When FAILED, the error message.
  blockReason     String?                    @db.Text
  errorMessage    String?                    @db.Text
  createdAt       DateTime                   @default(now())
  committedAt     DateTime?

  returnCase HelpdeskReturnCase @relation(fields: [returnCaseId], references: [id], onDelete: Cascade)

  @@unique([idempotencyKey])
  @@index([returnCaseId, createdAt])
  @@index([integrationId, createdAt])
  @@index([actionType, status])
  @@map("helpdesk_return_action_attempts")
}

/// Pull-only sync watermark for the returns feature, kept separate from
/// HelpdeskSyncCheckpoint so the returns sync cadence is independent.
model HelpdeskReturnSyncCheckpoint {
  id             String    @id @default(cuid())
  integrationId  String
  lastWatermark  DateTime?
  lastFullSyncAt DateTime?
  backfillDone   Boolean   @default(false)
  metadata       Json      @default("{}")
  updatedAt      DateTime  @updatedAt
  createdAt      DateTime  @default(now())

  @@unique([integrationId])
  @@map("helpdesk_return_sync_checkpoints")
}
