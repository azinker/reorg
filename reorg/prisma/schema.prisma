// ─── Auto Responder ──────────────────────────────────────────────────────────

model AutoResponder {
  id              String              @id @default(cuid())
  messageName     String
  channel         Platform
  integrationId   String
  subjectTemplate String
  bodyTemplate    String              @db.Text
  status          AutoResponderStatus @default(INACTIVE)
  activatedAt     DateTime?
  deactivatedAt   DateTime?
  archivedAt      DateTime?
  createdById     String
  updatedById     String
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  integration Integration            @relation(fields: [integrationId], references: [id])
  createdBy   User                   @relation("AutoResponderCreator", fields: [createdById], references: [id])
  updatedBy   User                   @relation("AutoResponderUpdater", fields: [updatedById], references: [id])
  versions    AutoResponderVersion[]
  sendLogs    AutoResponderSendLog[] @relation("SendLogResponder")
  jobs        AutoResponderJob[]     @relation("JobResponder")

  @@index([channel, status])
  @@index([integrationId])
  @@index([status])
  @@map("auto_responders")
}

model AutoResponderVersion {
  id               String   @id @default(cuid())
  responderId      String
  versionNumber    Int
  subjectTemplate  String
  bodyTemplate     String   @db.Text
  validationStatus String   @default("valid")
  createdById      String
  createdAt        DateTime @default(now())

  responder AutoResponder          @relation(fields: [responderId], references: [id], onDelete: Cascade)
  createdBy User                   @relation("AutoResponderVersionCreator", fields: [createdById], references: [id])
  sendLogs  AutoResponderSendLog[] @relation("SendLogVersion")
  jobs      AutoResponderJob[]     @relation("JobVersion")

  @@unique([responderId, versionNumber])
  @@index([responderId, createdAt])
  @@map("auto_responder_versions")
}

model AutoResponderSendLog {
  id                 String                 @id @default(cuid())
  responderId        String?
  responderVersionId String?
  integrationId      String
  channel            Platform
  orderNumber        String
  eventType          AutoResponderEventType
  source             AutoResponderSource
  renderedSubject    String?
  renderedBody       String?                @db.Text
  status             String?
  reason             String?
  externalMessageId  String?
  ebayItemId         String?
  ebayBuyerUserId    String?
  queuedAt           DateTime?
  attemptedAt        DateTime?
  sentAt             DateTime?
  failedAt           DateTime?
  retryCount         Int                    @default(0)
  bytesEstimate      Int?
  createdAt          DateTime               @default(now())

  responder        AutoResponder?        @relation("SendLogResponder", fields: [responderId], references: [id], onDelete: SetNull)
  responderVersion AutoResponderVersion? @relation("SendLogVersion", fields: [responderVersionId], references: [id], onDelete: SetNull)
  integration      Integration           @relation("SendLogIntegration", fields: [integrationId], references: [id])

  @@unique([orderNumber, channel], name: "auto_responder_dedupe")
  @@index([channel, createdAt])
  @@index([responderId, createdAt])
  @@index([eventType, createdAt])
  @@index([orderNumber])
  @@index([createdAt])
  @@map("auto_responder_send_logs")
}

model AutoResponderJob {
  id                 String                 @id @default(cuid())
  responderId        String
  responderVersionId String
  integrationId      String
  channel            Platform
  orderNumber        String
  trackingNumber     String?
  carrier            String?
  ebayItemId         String?
  ebayBuyerUserId    String?
  buyerName          String?
  itemTitle          String?
  source             AutoResponderSource
  status             AutoResponderJobStatus @default(PENDING)
  retryCount         Int                    @default(0)
  lastError          String?
  batchId            String?
  processAfter       DateTime               @default(now())
  createdAt          DateTime               @default(now())
  updatedAt          DateTime               @updatedAt

  responder        AutoResponder        @relation("JobResponder", fields: [responderId], references: [id], onDelete: Cascade)
  responderVersion AutoResponderVersion @relation("JobVersion", fields: [responderVersionId], references: [id], onDelete: Cascade)
  integration      Integration          @relation("JobIntegration", fields: [integrationId], references: [id])

  @@index([status, processAfter])
  @@index([channel, status])
  @@index([orderNumber])
  @@index([batchId])
  @@map("auto_responder_jobs")
}

// ─── Help Desk ───────────────────────────────────────────────────────────────

model HelpdeskTicket {
  id                 String               @id @default(cuid())
  integrationId      String
  channel            Platform
  threadKey          String
  buyerUserId        String?
  buyerName          String?
  buyerEmail         String?
  ebayItemId         String?
  ebayItemTitle      String?
  ebayOrderNumber    String?
  subject            String?
  kind               HelpdeskTicketKind   @default(POST_SALES)
  /// Practical classification — see HelpdeskTicketType. Default QUERY for
  /// untriaged messages; auto-detected by the inbound sync where possible.
  type               HelpdeskTicketType   @default(QUERY)
  /// True once an agent has manually set `type`. Auto-detection skips
  /// tickets where this is true so we never silently revert an override.
  typeOverridden     Boolean              @default(false)
  status             HelpdeskTicketStatus @default(NEW)
  isSpam             Boolean              @default(false)
  isArchived         Boolean              @default(false)
  /// Team-wide favorite (any agent can favorite/unfavorite). Surfaces in the
  /// Favorites sidebar folder. Distinct from `isImportant` which is just a
  /// per-row visual badge in the inbox.
  isFavorite         Boolean              @default(false)
  /// Marks the row with a flag badge in the inbox. Doesn't change folder
  /// routing — purely a visual "look at this one" hint.
  isImportant        Boolean              @default(false)
  archivedAt         DateTime?
  snoozedUntil       DateTime?
  snoozedById        String?
  primaryAssigneeId  String?
  unreadCount        Int                  @default(0)
  lastBuyerMessageAt DateTime?
  lastAgentMessageAt DateTime?
  firstResponseAt    DateTime?
  reopenCount        Int                  @default(0)
  lastReopenedAt     DateTime?
  resolvedAt         DateTime?
  resolvedById       String?
  metadata           Json                 @default("{}")
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt

  integration         Integration            @relation("HelpdeskIntegration", fields: [integrationId], references: [id])
  primaryAssignee     User?                  @relation("HelpdeskPrimaryAssignee", fields: [primaryAssigneeId], references: [id], onDelete: SetNull)
  resolvedBy          User?                  @relation("HelpdeskResolvedBy", fields: [resolvedById], references: [id], onDelete: SetNull)
  snoozedBy           User?                  @relation("HelpdeskSnoozedBy", fields: [snoozedById], references: [id], onDelete: SetNull)
  messages            HelpdeskMessage[]
  notes               HelpdeskNote[]
  tags                HelpdeskTicketTag[]
  drafts              HelpdeskDraft[]
  outboundJobs        HelpdeskOutboundJob[]
  notifications       HelpdeskNotification[]
  additionalAssignees HelpdeskAssignment[]
  presence            HelpdeskPresence[]     @relation("HelpdeskTicketPresence")

  @@unique([integrationId, threadKey])
  @@index([status, lastBuyerMessageAt])
  @@index([primaryAssigneeId, status])
  @@index([integrationId, status])
  @@index([buyerUserId])
  @@index([ebayOrderNumber])
  @@index([snoozedUntil])
  @@index([kind, status])
  @@index([isArchived, status])
  @@index([isFavorite])
  @@index([type])
  @@map("helpdesk_tickets")
}

model HelpdeskMessage {
  id             String                   @id @default(cuid())
  ticketId       String
  direction      HelpdeskMessageDirection
  source         HelpdeskMessageSource
  externalId     String?
  ebayMessageId  String?
  authorUserId   String?
  fromName       String?
  fromIdentifier String?
  subject        String?
  bodyText       String                   @db.Text
  isHtml         Boolean                  @default(false)
  rawMedia       Json                     @default("[]")
  rawData        Json                     @default("{}")
  sentAt         DateTime
  receivedAt     DateTime                 @default(now())
  deletedAt      DateTime?
  createdAt      DateTime                 @default(now())

  ticket HelpdeskTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  author User?          @relation("HelpdeskMessageAuthor", fields: [authorUserId], references: [id], onDelete: SetNull)

  @@unique([ticketId, externalId])
  @@index([ticketId, sentAt])
  @@index([ebayMessageId])
  @@index([direction, sentAt])
  @@map("helpdesk_messages")
}

model HelpdeskNote {
  id           String    @id @default(cuid())
  ticketId     String
  authorUserId String
  bodyText     String    @db.Text
  mentions     Json      @default("[]")
  isDeleted    Boolean   @default(false)
  deletedAt    DateTime?
  editedAt     DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  ticket HelpdeskTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  author User           @relation("HelpdeskNoteAuthor", fields: [authorUserId], references: [id])

  @@index([ticketId, createdAt])
  @@index([authorUserId])
  @@map("helpdesk_notes")
}

model HelpdeskTag {
  id          String   @id @default(cuid())
  name        String   @unique
  color       String?
  description String?
  createdById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  createdBy User?               @relation("HelpdeskTagCreator", fields: [createdById], references: [id], onDelete: SetNull)
  tickets   HelpdeskTicketTag[]

  @@index([name])
  @@map("helpdesk_tags")
}

model HelpdeskTicketTag {
  ticketId  String
  tagId     String
  addedById String?
  addedAt   DateTime @default(now())

  ticket  HelpdeskTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  tag     HelpdeskTag    @relation(fields: [tagId], references: [id], onDelete: Cascade)
  addedBy User?          @relation("HelpdeskTagAdder", fields: [addedById], references: [id], onDelete: SetNull)

  @@id([ticketId, tagId])
  @@index([tagId])
  @@map("helpdesk_ticket_tags")
}

model HelpdeskAssignment {
  ticketId   String
  userId     String
  role       String   @default("ADDITIONAL")
  assignedAt DateTime @default(now())

  ticket HelpdeskTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  user   User           @relation("HelpdeskAssignmentUser", fields: [userId], references: [id], onDelete: Cascade)

  @@id([ticketId, userId])
  @@index([userId])
  @@map("helpdesk_assignments")
}

/// Per-user inbox column preferences. The shape of `columns` is defined by
/// the client (`InboxColumnKey[]` in TicketList) so we can add/rename
/// columns without a migration. Each row represents a single user's view of
/// a single inbox layout (currently always "table" — kept open so we can
/// fork "list" prefs in future without another model).
///
/// Persisted server-side so prefs follow the agent across browsers/devices.
model HelpdeskColumnPref {
  userId    String
  layout    String   @default("table")
  /// Ordered array of column keys to render, e.g.
  /// `["channel","customer","type","latestUpdate","owner","timeLeft","created","status","orderId","ebayUsername"]`.
  /// Columns not present here are hidden.
  columns   Json     @default("[]")
  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())

  user User @relation("HelpdeskColumnPrefUser", fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, layout])
  @@map("helpdesk_column_prefs")
}

/// Live "agent X is currently viewing ticket Y" state. The client posts a
/// heartbeat every ~10s while the ticket detail tab is foreground; the row
/// is considered live for `expiresAt > now()`. Purged lazily by /presence
/// reads and by a scheduled cleanup. Composite PK so a single agent can only
/// occupy one slot per ticket — re-heartbeating just bumps `expiresAt`.
model HelpdeskPresence {
  ticketId      String
  userId        String
  lastSeenAt    DateTime @default(now())
  expiresAt     DateTime
  /// Free-form client surface marker (e.g. "viewer" vs "composing") so we
  /// can later distinguish "reading" vs "typing a reply" without a schema
  /// change. Default "viewer" today.
  presenceState String   @default("viewer")

  ticket HelpdeskTicket @relation("HelpdeskTicketPresence", fields: [ticketId], references: [id], onDelete: Cascade)
  user   User           @relation("HelpdeskPresenceUser", fields: [userId], references: [id], onDelete: Cascade)

  @@id([ticketId, userId])
  @@index([ticketId, expiresAt])
  @@index([expiresAt])
  @@map("helpdesk_presence")
}

model HelpdeskTemplate {
  id          String   @id @default(cuid())
  name        String
  bodyText    String   @db.Text
  isShared    Boolean  @default(true)
  ownerUserId String?
  shortcut    String?
  language    String?
  description String?
  sortOrder   Int      @default(0)
  isActive    Boolean  @default(true)
  createdById String
  updatedById String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  owner     User? @relation("HelpdeskTemplateOwner", fields: [ownerUserId], references: [id], onDelete: SetNull)
  createdBy User  @relation("HelpdeskTemplateCreator", fields: [createdById], references: [id])
  updatedBy User  @relation("HelpdeskTemplateUpdater", fields: [updatedById], references: [id])

  @@index([isShared, isActive])
  @@index([ownerUserId])
  @@index([shortcut])
  @@map("helpdesk_templates")
}

model HelpdeskDraft {
  id           String               @id @default(cuid())
  ticketId     String
  authorUserId String
  composerMode HelpdeskComposerMode @default(REPLY)
  bodyText     String               @db.Text
  metadata     Json                 @default("{}")
  updatedAt    DateTime             @updatedAt
  createdAt    DateTime             @default(now())

  ticket HelpdeskTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  author User           @relation("HelpdeskDraftAuthor", fields: [authorUserId], references: [id], onDelete: Cascade)

  @@unique([ticketId, authorUserId, composerMode])
  @@index([authorUserId])
  @@map("helpdesk_drafts")
}

model HelpdeskOutboundJob {
  id              String                 @id @default(cuid())
  ticketId        String
  authorUserId    String
  composerMode    HelpdeskComposerMode
  bodyText        String                 @db.Text
  parentMessageId String?
  setStatus       HelpdeskTicketStatus?
  scheduledAt     DateTime
  status          HelpdeskOutboundStatus @default(PENDING)
  attemptCount    Int                    @default(0)
  lastError       String?
  externalId      String?
  sentAt          DateTime?
  metadata        Json                   @default("{}")
  createdAt       DateTime               @default(now())
  updatedAt       DateTime               @updatedAt

  ticket HelpdeskTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  author User           @relation("HelpdeskOutboundAuthor", fields: [authorUserId], references: [id])

  @@index([status, scheduledAt])
  @@index([ticketId, status])
  @@index([authorUserId])
  @@map("helpdesk_outbound_jobs")
}

model HelpdeskNotification {
  id          String    @id @default(cuid())
  recipientId String
  ticketId    String?
  kind        String
  bodyText    String
  url         String?
  readAt      DateTime?
  createdAt   DateTime  @default(now())

  recipient User            @relation("HelpdeskNotificationRecipient", fields: [recipientId], references: [id], onDelete: Cascade)
  ticket    HelpdeskTicket? @relation(fields: [ticketId], references: [id], onDelete: SetNull)

  @@index([recipientId, readAt])
  @@index([ticketId])
  @@index([createdAt])
  @@map("helpdesk_notifications")
}

model HelpdeskSyncCheckpoint {
  id             String    @id @default(cuid())
  integrationId  String
  folder         String
  lastWatermark  DateTime?
  lastFullSyncAt DateTime?
  backfillCursor DateTime?
  backfillDone   Boolean   @default(false)
  metadata       Json      @default("{}")
  updatedAt      DateTime  @updatedAt
  createdAt      DateTime  @default(now())

  @@unique([integrationId, folder])
  @@index([integrationId])
  @@map("helpdesk_sync_checkpoints")
}

/// User-defined inbox rules (e.g. "Subject contains 'Shipped' → Archive").
/// Rules are evaluated against incoming messages on every sync tick AND can be
/// run on-demand against the existing inbox via `Run filter`.
///
/// `conditions` shape (JSON):
///   {
///     "match": "ALL" | "ANY",            // boolean combinator
///     "rules": [
///       { "field": "subject" | "body" | "buyer_username" | "from_name",
///         "op":    "contains" | "equals" | "starts_with" | "ends_with" | "regex",
///         "value": "...",
///         "caseSensitive": false }
///     ]
///   }
///
/// `action` shape (JSON):
///   {
///     "type": "MOVE_TO_FOLDER",
///     "folder": "archived" | "spam" | "resolved",
///     "addTagIds": ["..."],              // optional
///     "removeTagIds": ["..."],           // optional
///     "assignToUserId": "..."            // optional
///   }
model HelpdeskFilter {
  id          String   @id @default(cuid())
  name        String
  description String?
  enabled     Boolean  @default(true)
  isSystem    Boolean  @default(false)
  sortOrder   Int      @default(0)
  conditions  Json
  action      Json
  lastRunAt   DateTime?
  lastRunHits Int       @default(0)
  totalHits   Int       @default(0)
  createdById String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  createdBy User? @relation("HelpdeskFilterCreator", fields: [createdById], references: [id], onDelete: SetNull)

  @@index([enabled, sortOrder])
  @@map("helpdesk_filters")
}
