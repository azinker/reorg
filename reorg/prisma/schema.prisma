generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum Role {
  ADMIN
  OPERATOR
}

enum Platform {
  TPP_EBAY
  TT_EBAY
  BIGCOMMERCE
  SHOPIFY
  AMAZON
}

enum SyncStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
}

enum ChangeStatus {
  STAGED
  PUSHED
  CANCELLED
  LOCAL_ONLY
}

enum PushJobStatus {
  PENDING
  DRY_RUN
  CONFIRMED
  EXECUTING
  COMPLETED
  FAILED
}

enum BackupType {
  DAILY
  MANUAL
  PRE_PUSH
}

enum BackupStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  FAILED
}

enum ListingStatus {
  ACTIVE
  OUT_OF_STOCK
}

enum ForecastBucket {
  DAILY
  WEEKLY
}

enum ForecastConfidence {
  HIGH
  MEDIUM
  LOW
}

enum DemandPattern {
  STABLE
  TRENDING
  SEASONAL
  INTERMITTENT
  NEW_ITEM
  SLOW_MOVER
}

enum SupplierOrderStatus {
  DRAFT
  ORDERED
  IN_TRANSIT
  RECEIVED
  CANCELLED
}

enum InventorySourceType {
  MASTER_TPP_LIVE
}

enum NetworkTransferChannel {
  CLIENT_API_RESPONSE
  MARKETPLACE_INBOUND
  MARKETPLACE_OUTBOUND
  SYNC_JOB
  FORECAST
  AUTO_RESPONDER
  DATABASE_IO
  WEBHOOK_INBOUND
  OTHER
}

enum AutoResponderStatus {
  ACTIVE
  INACTIVE
  ARCHIVED
  INVALID
}

enum AutoResponderEventType {
  QUEUED
  SENT
  FAILED
  SKIPPED
  DUPLICATE_PREVENTED
  NO_ACTIVE_RESPONDER
  PREVIEW
  TEST_SEND
  INTEGRATION_DISABLED
  RESPONDER_AUTO_DISABLED
}

enum AutoResponderSource {
  SHIP_ORDERS
  RECONCILIATION
  PREVIEW
  TESTING_AREA
}

enum AutoResponderJobStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  PAUSED
}

enum TaskStatus {
  OPEN
  IN_PROGRESS
  BLOCKED
  COMPLETED
}

enum TaskUrgency {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum TaskActivityType {
  CREATED
  UPDATED
  COMPLETED
  REOPENED
  DELETED
  RESTORED
}

enum RevenueFinancialEventType {
  TRANSACTION
  BILLING_ACTIVITY
  SUMMARY
}

enum RevenueFinancialEventClassification {
  SALE
  TAX
  MARKETPLACE_FEE
  ADVERTISING_FEE
  SHIPPING_LABEL
  ACCOUNT_LEVEL_FEE
  CREDIT
  OTHER
}

// ─── Help Desk enums ─────────────────────────────────────────────────────────

enum HelpdeskTicketStatus {
  NEW
  TO_DO
  WAITING
  RESOLVED
  SPAM
  ARCHIVED
}

enum HelpdeskTicketKind {
  PRE_SALES
  POST_SALES
}

/// Practical, agent-facing classification of WHAT the ticket is about.
/// Distinct from `HelpdeskTicketKind` (PRE_SALES/POST_SALES) because that one
/// answers "is this before or after a purchase?" while this one answers
/// "what bucket does this belong in for triage / routing / reporting?".
///
/// Set automatically by the inbound sync when we can pattern-match the
/// message (e.g. eBay return events → RETURN_REQUEST). An agent can always
/// override via the per-ticket header bar; manual overrides win and are not
/// reverted by subsequent syncs.
enum HelpdeskTicketType {
  QUERY                 // generic buyer message — the default
  PRE_SALES             // pre-purchase question
  RETURN_REQUEST        // buyer initiated an eBay return
  ITEM_NOT_RECEIVED     // INR claim
  NEGATIVE_FEEDBACK     // buyer left negative feedback or threatened to
  REFUND                // refund request
  SHIPPING_QUERY        // tracking / delivery / customs questions
  CANCELLATION          // buyer wants to cancel
  OTHER
}

enum HelpdeskMessageDirection {
  INBOUND
  OUTBOUND
}

enum HelpdeskMessageSource {
  EBAY
  EBAY_UI
  EXTERNAL_EMAIL
  SYSTEM
}

enum HelpdeskComposerMode {
  REPLY
  NOTE
  EXTERNAL
}

enum HelpdeskOutboundStatus {
  PENDING
  SENDING
  SENT
  FAILED
  CANCELED
}

// ─── Auth & Users ────────────────────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  passwordHash  String?
  emailVerified DateTime?
  image         String?
  role          Role      @default(OPERATOR)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  handle    String? @unique
  avatarUrl String?
  title     String?
  bio       String? @db.Text

  /// Per-user page allowlist. NULL = legacy default (operators see everything
  /// except admin-only pages). Empty array = only "always-allowed" pages
  /// (Dashboard, Users-as-self, Settings). Otherwise the listed page keys are
  /// granted in addition to the always-allowed set. Admin role overrides this.
  /// Page keys are defined in src/lib/nav-pages.ts.
  pagePermissions Json?

  accounts              Account[]
  sessions              Session[]
  stagedChanges         StagedChange[]
  pushJobs              PushJob[]
  auditLogs             AuditLog[]
  createdTasks          Task[]                 @relation("TaskCreator")
  assignedTasks         Task[]                 @relation("TaskAssignee")
  deletedTasks          Task[]                 @relation("TaskDeleter")
  taskActivities        TaskActivity[]         @relation("TaskActivityActor")
  revenueSyncJobs       RevenueSyncJob[]       @relation("RevenueSyncJobTrigger")
  forecastRuns          ForecastRun[]
  supplierOrders        SupplierOrder[]
  createdAutoResponders AutoResponder[]        @relation("AutoResponderCreator")
  updatedAutoResponders AutoResponder[]        @relation("AutoResponderUpdater")
  autoResponderVersions AutoResponderVersion[] @relation("AutoResponderVersionCreator")

  helpdeskPrimaryAssignments HelpdeskTicket[]       @relation("HelpdeskPrimaryAssignee")
  helpdeskResolvedTickets    HelpdeskTicket[]       @relation("HelpdeskResolvedBy")
  helpdeskSnoozedTickets     HelpdeskTicket[]       @relation("HelpdeskSnoozedBy")
  helpdeskMessages           HelpdeskMessage[]      @relation("HelpdeskMessageAuthor")
  helpdeskNotes              HelpdeskNote[]         @relation("HelpdeskNoteAuthor")
  helpdeskCreatedTags        HelpdeskTag[]          @relation("HelpdeskTagCreator")
  helpdeskAddedTags          HelpdeskTicketTag[]    @relation("HelpdeskTagAdder")
  helpdeskAssignments        HelpdeskAssignment[]   @relation("HelpdeskAssignmentUser")
  helpdeskOwnedTemplates     HelpdeskTemplate[]     @relation("HelpdeskTemplateOwner")
  helpdeskCreatedTemplates   HelpdeskTemplate[]     @relation("HelpdeskTemplateCreator")
  helpdeskUpdatedTemplates   HelpdeskTemplate[]     @relation("HelpdeskTemplateUpdater")
  helpdeskDrafts             HelpdeskDraft[]        @relation("HelpdeskDraftAuthor")
  helpdeskOutboundJobs       HelpdeskOutboundJob[]  @relation("HelpdeskOutboundAuthor")
  helpdeskNotifications      HelpdeskNotification[] @relation("HelpdeskNotificationRecipient")
  helpdeskCreatedFilters     HelpdeskFilter[]       @relation("HelpdeskFilterCreator")
  helpdeskColumnPrefs        HelpdeskColumnPref[]   @relation("HelpdeskColumnPrefUser")
  helpdeskPresence           HelpdeskPresence[]     @relation("HelpdeskPresenceUser")

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ─── Integrations ────────────────────────────────────────────────────────────

model Integration {
  id          String    @id @default(cuid())
  platform    Platform  @unique
  label       String
  enabled     Boolean   @default(false)
  isMaster    Boolean   @default(false)
  writeLocked Boolean   @default(true)
  config      Json      @default("{}")
  lastSyncAt  DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  listings               MarketplaceListing[]
  unmatchedListings      UnmatchedListing[]
  syncJobs               SyncJob[]
  revenueSyncJobs        RevenueSyncJob[]
  revenueFinancialEvents RevenueFinancialEvent[]
  networkTransferSamples NetworkTransferSample[]
  autoResponders         AutoResponder[]
  autoResponderSendLogs  AutoResponderSendLog[]  @relation("SendLogIntegration")
  autoResponderJobs      AutoResponderJob[]      @relation("JobIntegration")
  helpdeskTickets        HelpdeskTicket[]        @relation("HelpdeskIntegration")

  @@map("integrations")
}

// ─── Core Data Model ─────────────────────────────────────────────────────────

model MasterRow {
  id                   String   @id @default(cuid())
  sku                  String   @unique
  title                String?
  alternateTitles      Json     @default("[]")
  imageUrl             String?
  imageSource          String?
  upc                  String?
  weight               String?
  weightDisplay        String?
  weightOz             Float?
  supplierCost         Float?
  supplierShipping     Float?
  shippingCostOverride Float?
  platformFeeRate      Float    @default(0.136)
  notes                String?
  isActive             Boolean  @default(true)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  listings           MarketplaceListing[]
  stagedChanges      StagedChange[]
  saleHistoryLines   MarketplaceSaleLine[]
  inventorySnapshots InventorySnapshot[]
  forecastRunLines   ForecastRunLine[]
  supplierOrderLines SupplierOrderLine[]

  @@index([sku])
  @@index([title])
  @@map("master_rows")
}

model MarketplaceListing {
  id                String        @id @default(cuid())
  masterRowId       String
  integrationId     String
  platformItemId    String
  platformVariantId String?
  sku               String
  title             String?
  imageUrl          String?
  salePrice         Float?
  adRate            Float?
  inventory         Int?
  status            ListingStatus @default(ACTIVE)
  isVariation       Boolean       @default(false)
  parentListingId   String?
  rawData           Json          @default("{}")
  lastSyncedAt      DateTime?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  masterRow     MasterRow            @relation(fields: [masterRowId], references: [id])
  integration   Integration          @relation(fields: [integrationId], references: [id])
  parentListing MarketplaceListing?  @relation("VariationParent", fields: [parentListingId], references: [id])
  childListings MarketplaceListing[] @relation("VariationParent")
  stagedChanges StagedChange[]

  @@unique([integrationId, platformItemId, platformVariantId])
  @@index([sku])
  @@index([masterRowId])
  @@index([integrationId])
  @@index([parentListingId])
  @@map("marketplace_listings")
}

model UnmatchedListing {
  id             String    @id @default(cuid())
  integrationId  String
  platformItemId String
  sku            String?
  title          String?
  rawData        Json      @default("{}")
  lastSyncedAt   DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  integration Integration @relation(fields: [integrationId], references: [id])

  @@unique([integrationId, platformItemId])
  @@index([sku])
  @@map("unmatched_listings")
}

// ─── Staged Changes ──────────────────────────────────────────────────────────

model StagedChange {
  id                   String       @id @default(cuid())
  masterRowId          String
  marketplaceListingId String?
  field                String
  stagedValue          String
  liveValue            String?
  changedById          String
  status               ChangeStatus @default(STAGED)
  rejectionReason      String?
  pushedAt             DateTime?
  createdAt            DateTime     @default(now())
  updatedAt            DateTime     @updatedAt

  masterRow          MasterRow           @relation(fields: [masterRowId], references: [id])
  marketplaceListing MarketplaceListing? @relation(fields: [marketplaceListingId], references: [id])
  changedBy          User                @relation(fields: [changedById], references: [id])

  @@index([masterRowId])
  @@index([status])
  @@index([changedById])
  @@map("staged_changes")
}

// ─── Shipping Rate Table ─────────────────────────────────────────────────────

model ShippingRate {
  id        String @id @default(cuid())
  weightKey String @unique
  weightOz  Float
  cost      Float?
  sortOrder Int    @default(0)

  @@map("shipping_rates")
}

// ─── Sync & Push Jobs ────────────────────────────────────────────────────────

model SyncJob {
  id             String     @id @default(cuid())
  integrationId  String
  status         SyncStatus @default(PENDING)
  triggeredBy    String?
  itemsProcessed Int        @default(0)
  itemsCreated   Int        @default(0)
  itemsUpdated   Int        @default(0)
  errors         Json       @default("[]")
  startedAt      DateTime?
  completedAt    DateTime?
  createdAt      DateTime   @default(now())

  integration Integration @relation(fields: [integrationId], references: [id])

  @@index([integrationId])
  @@index([status])
  @@map("sync_jobs")
}

model PushJob {
  id          String        @id @default(cuid())
  userId      String
  status      PushJobStatus @default(PENDING)
  dryRun      Boolean       @default(true)
  payload     Json          @default("[]")
  result      Json          @default("{}")
  createdAt   DateTime      @default(now())
  completedAt DateTime?

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([status])
  @@map("push_jobs")
}

// ─── Audit & Logs ────────────────────────────────────────────────────────────

model AuditLog {
  id         String   @id @default(cuid())
  userId     String?
  action     String
  entityType String?
  entityId   String?
  details    Json     @default("{}")
  createdAt  DateTime @default(now())

  user User? @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([action])
  @@index([entityType, entityId])
  @@index([createdAt])
  @@map("audit_logs")
}

model NetworkTransferSample {
  id            String                 @id @default(cuid())
  createdAt     DateTime               @default(now())
  channel       NetworkTransferChannel
  label         String
  bytesEstimate Int?
  durationMs    Int?
  metadata      Json                   @default("{}")
  integrationId String?

  integration Integration? @relation(fields: [integrationId], references: [id], onDelete: SetNull)

  @@index([createdAt])
  @@index([channel])
  @@index([integrationId])
  @@map("network_transfer_samples")
}

model NetworkTransferDailySummary {
  id            String                 @id @default(cuid())
  date          DateTime               @db.Date
  channel       NetworkTransferChannel
  label         String
  eventCount    Int
  bytesSum      BigInt
  avgDurationMs Int?
  createdAt     DateTime               @default(now())

  @@unique([date, channel, label])
  @@index([date])
  @@index([channel, date])
  @@map("network_transfer_daily_summaries")
}

// ─── Backups ─────────────────────────────────────────────────────────────────

model Backup {
  id         String       @id @default(cuid())
  type       BackupType
  storageKey String
  fileName   String
  size       Int?
  stores     Json         @default("[]")
  status     BackupStatus @default(PENDING)
  notes      String?
  expiresAt  DateTime
  createdAt  DateTime     @default(now())

  @@index([type])
  @@index([status])
  @@index([expiresAt])
  @@map("backups")
}

// ─── App Settings ────────────────────────────────────────────────────────────

model AppSetting {
  key       String   @id
  value     Json
  updatedBy String?
  updatedAt DateTime @updatedAt

  @@map("app_settings")
}

model TaskCategory {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  sortOrder Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tasks Task[]

  @@index([sortOrder])
  @@index([isActive])
  @@map("task_categories")
}

model Task {
  id               String      @id @default(cuid())
  title            String
  notes            String?
  status           TaskStatus  @default(OPEN)
  urgency          TaskUrgency @default(MEDIUM)
  categoryId       String
  createdByUserId  String
  assignedToUserId String?
  isSharedTeamTask Boolean     @default(false)
  dueAt            DateTime?
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt
  completedAt      DateTime?
  deletedAt        DateTime?
  deletedByUserId  String?
  restoredAt       DateTime?

  category   TaskCategory   @relation(fields: [categoryId], references: [id])
  createdBy  User           @relation("TaskCreator", fields: [createdByUserId], references: [id])
  assignedTo User?          @relation("TaskAssignee", fields: [assignedToUserId], references: [id], onDelete: SetNull)
  deletedBy  User?          @relation("TaskDeleter", fields: [deletedByUserId], references: [id], onDelete: SetNull)
  activities TaskActivity[]

  @@index([status, deletedAt, dueAt])
  @@index([createdByUserId, deletedAt])
  @@index([assignedToUserId, deletedAt])
  @@index([categoryId, deletedAt])
  @@index([deletedAt])
  @@map("tasks")
}

model TaskActivity {
  id          String           @id @default(cuid())
  taskId      String
  actorUserId String?
  type        TaskActivityType
  details     Json             @default("{}")
  createdAt   DateTime         @default(now())

  task  Task  @relation(fields: [taskId], references: [id], onDelete: Cascade)
  actor User? @relation("TaskActivityActor", fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([taskId, createdAt])
  @@index([actorUserId, createdAt])
  @@map("task_activities")
}

model MarketplaceSaleOrder {
  id                      String    @id @default(cuid())
  platform                Platform
  externalOrderId         String
  orderDate               DateTime
  orderStatus             String?
  cancelledAt             DateTime?
  currencyCode            String?
  grossRevenueAmount      Float?
  shippingCollectedAmount Float?
  taxCollectedAmount      Float?
  discountAmount          Float?
  netRevenueAmount        Float?
  buyerIdentifier         String?
  buyerDisplayLabel       String?
  buyerEmail              String?
  rawData                 Json      @default("{}")
  financialRawData        Json      @default("{}")
  createdAt               DateTime  @default(now())
  updatedAt               DateTime  @updatedAt

  lines MarketplaceSaleLine[]

  @@unique([platform, externalOrderId])
  @@index([platform, orderDate])
  @@index([orderDate])
  @@index([platform, buyerIdentifier])
  @@map("marketplace_sale_orders")
}

model MarketplaceSaleLine {
  id                     String   @id @default(cuid())
  marketplaceSaleOrderId String
  masterRowId            String?
  platform               Platform
  externalLineId         String
  orderDate              DateTime
  sku                    String
  title                  String?
  platformItemId         String?
  platformVariantId      String?
  quantity               Int
  unitPriceAmount        Float?
  grossRevenueAmount     Float?
  marketplaceFeeAmount   Float?
  advertisingFeeAmount   Float?
  otherFeeAmount         Float?
  taxAmount              Float?
  shippingAmount         Float?
  netRevenueAmount       Float?
  isCancelled            Boolean  @default(false)
  isReturn               Boolean  @default(false)
  rawData                Json     @default("{}")
  financialRawData       Json     @default("{}")
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  marketplaceSaleOrder MarketplaceSaleOrder @relation(fields: [marketplaceSaleOrderId], references: [id], onDelete: Cascade)
  masterRow            MasterRow?           @relation(fields: [masterRowId], references: [id], onDelete: SetNull)

  @@unique([marketplaceSaleOrderId, externalLineId])
  @@index([masterRowId])
  @@index([sku])
  @@index([platform, orderDate])
  @@index([platform, sku])
  @@index([orderDate])
  @@map("marketplace_sale_lines")
}

model RevenueSyncJob {
  id                String     @id @default(cuid())
  integrationId     String
  platform          Platform
  triggeredByUserId String?
  status            SyncStatus @default(PENDING)
  startedAt         DateTime?
  completedAt       DateTime?
  ordersProcessed   Int        @default(0)
  linesProcessed    Int        @default(0)
  warningCount      Int        @default(0)
  warnings          Json       @default("[]")
  errorSummary      String?
  metadata          Json       @default("{}")
  createdAt         DateTime   @default(now())

  integration Integration @relation(fields: [integrationId], references: [id])
  triggeredBy User?       @relation("RevenueSyncJobTrigger", fields: [triggeredByUserId], references: [id], onDelete: SetNull)

  @@index([integrationId, createdAt])
  @@index([platform, createdAt])
  @@index([status, createdAt])
  @@map("revenue_sync_jobs")
}

model RevenueFinancialEvent {
  id                 String                              @id @default(cuid())
  integrationId      String
  platform           Platform
  eventType          RevenueFinancialEventType
  classification     RevenueFinancialEventClassification
  externalEventId    String
  externalOrderId    String?
  externalLineId     String?
  platformItemId     String?
  sku                String?
  occurredAt         DateTime
  amount             Float
  currencyCode       String?
  feeType            String?
  feeTypeDescription String?
  bookingEntry       String?
  isExact            Boolean                             @default(true)
  rawData            Json                                @default("{}")
  createdAt          DateTime                            @default(now())
  updatedAt          DateTime                            @updatedAt

  integration Integration @relation(fields: [integrationId], references: [id], onDelete: Cascade)

  @@unique([integrationId, eventType, externalEventId])
  @@index([platform, occurredAt])
  @@index([integrationId, occurredAt])
  @@index([classification, occurredAt])
  @@index([externalOrderId])
  @@index([platformItemId])
  @@map("revenue_financial_events")
}

model InventorySnapshot {
  id           String              @id @default(cuid())
  masterRowId  String
  snapshotDate DateTime
  quantity     Int
  source       InventorySourceType @default(MASTER_TPP_LIVE)
  isNearZero   Boolean             @default(false)
  createdAt    DateTime            @default(now())

  masterRow MasterRow @relation(fields: [masterRowId], references: [id], onDelete: Cascade)

  @@unique([masterRowId, snapshotDate, source])
  @@index([snapshotDate])
  @@index([source, snapshotDate])
  @@map("inventory_snapshots")
}

model ForecastRun {
  id                      String              @id @default(cuid())
  createdById             String?
  lookbackDays            Int
  forecastBucket          ForecastBucket      @default(WEEKLY)
  transitDays             Int
  desiredCoverageDays     Int
  useOpenInTransit        Boolean             @default(true)
  showReorderRelevantOnly Boolean             @default(true)
  mode                    String              @default("balanced")
  inventorySource         InventorySourceType @default(MASTER_TPP_LIVE)
  syncedSalesThrough      DateTime?
  summary                 Json                @default("{}")
  createdAt               DateTime            @default(now())
  updatedAt               DateTime            @updatedAt

  createdBy      User?             @relation(fields: [createdById], references: [id], onDelete: SetNull)
  lines          ForecastRunLine[]
  supplierOrders SupplierOrder[]

  @@index([createdById])
  @@index([createdAt])
  @@map("forecast_runs")
}

model ForecastRunLine {
  id                      String             @id @default(cuid())
  forecastRunId           String
  masterRowId             String
  title                   String?
  sku                     String
  upc                     String?
  imageUrl                String?
  supplierCost            Float?
  currentInventory        Int                @default(0)
  salesTotalUnits         Int                @default(0)
  salesHistoryDays        Int                @default(0)
  averageDailyDemand      Float              @default(0)
  transitDemand           Float              @default(0)
  postArrivalDemand       Float              @default(0)
  safetyBuffer            Float              @default(0)
  grossRequiredQty        Float              @default(0)
  openInTransitQty        Int                @default(0)
  openInTransitEta        DateTime?
  projectedStockOnArrival Float              @default(0)
  recommendedQty          Int                @default(0)
  overrideQty             Int?
  finalQty                Int                @default(0)
  demandPattern           DemandPattern      @default(NEW_ITEM)
  modelUsed               String
  confidence              ForecastConfidence @default(LOW)
  confidenceNote          String?
  warningFlags            Json               @default("[]")
  backtestError           Float?
  suspectedStockout       Boolean            @default(false)
  limitedHistory          Boolean            @default(false)
  hasInbound              Boolean            @default(false)
  createdAt               DateTime           @default(now())
  updatedAt               DateTime           @updatedAt

  forecastRun ForecastRun @relation(fields: [forecastRunId], references: [id], onDelete: Cascade)
  masterRow   MasterRow   @relation(fields: [masterRowId], references: [id], onDelete: Cascade)

  @@unique([forecastRunId, masterRowId])
  @@index([forecastRunId])
  @@index([masterRowId])
  @@index([title])
  @@map("forecast_run_lines")
}

model SupplierOrder {
  id            String              @id @default(cuid())
  createdById   String?
  forecastRunId String?
  orderName     String?
  supplier      String?
  status        SupplierOrderStatus @default(DRAFT)
  eta           DateTime
  notes         String?
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt

  createdBy   User?               @relation(fields: [createdById], references: [id], onDelete: SetNull)
  forecastRun ForecastRun?        @relation(fields: [forecastRunId], references: [id], onDelete: SetNull)
  lines       SupplierOrderLine[]

  @@index([createdById])
  @@index([forecastRunId])
  @@index([status, eta])
  @@map("supplier_orders")
}

model SupplierOrderLine {
  id                   String   @id @default(cuid())
  supplierOrderId      String
  masterRowId          String
  title                String?
  sku                  String
  supplierCost         Float?
  systemRecommendedQty Int      @default(0)
  overrideQty          Int?
  finalQty             Int      @default(0)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  supplierOrder SupplierOrder @relation(fields: [supplierOrderId], references: [id], onDelete: Cascade)
  masterRow     MasterRow     @relation(fields: [masterRowId], references: [id], onDelete: Cascade)

  @@unique([supplierOrderId, masterRowId])
  @@index([supplierOrderId])
  @@index([masterRowId])
  @@index([title])
  @@map("supplier_order_lines")
